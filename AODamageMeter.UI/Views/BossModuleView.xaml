<Window x:Class="AODamageMeter.UI.Views.BossModuleView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:AODamageMeter.UI.Behaviors"
        Style="{StaticResource WindowStyle}" Background="Transparent"
        BorderBrush="{StaticResource LightBlueBrush50}" BorderThickness="1">
  <Window.Resources>
    <Style x:Key="StatusBarLabelStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect ShadowDepth="0" BlurRadius="4" Color="Black" Opacity="1"/>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="24"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0"
          Background="{StaticResource Black40}"
          MouseDown="HeaderRow_MouseDown_Drag">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="24"/>
        <ColumnDefinition Width="24"/>
        <ColumnDefinition Width="24"/>
      </Grid.ColumnDefinitions>

      <Image Grid.Column="0" Source="{Binding IconPath}" Width="20" Height="20" Margin="2 0 0 0"/>
      <TextBlock Grid.Column="1" Margin="3 0 0 0" VerticalAlignment="Center"
                 Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"/>
      <Button Grid.Column="2"
              Click="ResetButton_Click_Reset"
              ToolTip="Reset">
        <fa:ImageAwesome Icon="Refresh"/>
      </Button>
      <Button Grid.Column="3"
              Click="MinimizeButton_Click_Minimize"
              ToolTip="Minimize">
        <fa:ImageAwesome Icon="WindowMinimize"/>
      </Button>
      <Button Grid.Column="4"
              Click="CloseButton_Click_Close"
              ToolTip="Close">
        <fa:ImageAwesome Icon="Close"/>
      </Button>
    </Grid>

    <Grid Grid.Row="1" Margin="1"
          Background="{StaticResource DarkBlueBrush85}">
      <ContentControl x:Name="BossModuleViewContent"/>
    </Grid>

    <Border Grid.Row="1"
            BorderBrush="{StaticResource Black40}" BorderThickness="1"/>
    <Border Grid.Row="1" Margin="2 0 2 2"
            BorderBrush="{StaticResource LightBlueBrush}" BorderThickness="1"/>

    <Popup x:Name="StatusBarsPopup"
           PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Window}, Mode=OneTime}"
           Placement="Custom"
           IsOpen="{Binding HasStatusBars, Mode=OneWay}"
           StaysOpen="True"
           AllowsTransparency="True"
           Focusable="False">
      <ItemsControl ItemsSource="{Binding StatusBars}"
                    Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                    Background="Transparent">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Orientation="Vertical"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid Height="18" Margin="10 0 10 4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Image Grid.Column="0"
                     Source="{Binding IconPath}"
                     Width="18" Height="18"
                     Stretch="UniformToFill"/>
              <Grid Grid.Column="1">
                <ProgressBar Minimum="0"
                             Maximum="{Binding TotalSeconds, Mode=OneWay}"
                             Foreground="{Binding BarColor, Converter={StaticResource ColorToRowBrushConverter}}"
                             Background="{StaticResource DarkBlueBrush81}"
                             behaviors:StatusBarAnimation.StatusBarViewModel="{Binding}">
                  <ProgressBar.Template>
                    <ControlTemplate TargetType="ProgressBar">
                      <Grid>
                        <Border x:Name="PART_Track" Background="{TemplateBinding Background}"/>
                        <Decorator x:Name="PART_Indicator" HorizontalAlignment="Left">
                          <Rectangle Fill="{TemplateBinding Foreground}"/>
                        </Decorator>
                      </Grid>
                    </ControlTemplate>
                  </ProgressBar.Template>
                </ProgressBar>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="{Binding Label}"
                             Style="{StaticResource StatusBarLabelStyle}"
                             TextTrimming="CharacterEllipsis"
                             Margin="4 0 0 0"/>
                  <TextBlock Grid.Column="1" Text="{Binding TimeRemainingText}"
                             Style="{StaticResource StatusBarLabelStyle}"
                             Margin="0 0 4 0"/>
                </Grid>
              </Grid>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Popup>
  </Grid>
</Window>
