<Window x:Class="AODamageMeter.UI.Views.BossModuleView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:AODamageMeter.UI.Behaviors"
        Background="Transparent">
  <Window.Style>
    <Style TargetType="Window" BasedOn="{StaticResource WindowStyle}">
      <Setter Property="BorderBrush" Value="{StaticResource LightBlueBrush50}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsAggroSwapRecent, FallbackValue=False}" Value="True">
          <Setter Property="BorderBrush" Value="#D4A030"/>
          <Setter Property="BorderThickness" Value="2"/>
        </DataTrigger>
        <DataTrigger Binding="{Binding IsBossTargetingYou, FallbackValue=False}" Value="True">
          <Setter Property="BorderBrush" Value="#AA2222"/>
          <Setter Property="BorderThickness" Value="2"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>
  </Window.Style>
  <Window.Resources>
    <Style x:Key="StatusBarLabelStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect ShadowDepth="0" BlurRadius="4" Color="Black" Opacity="1"/>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="24"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" MouseDown="HeaderRow_MouseDown_Drag">
      <Grid.Style>
        <Style TargetType="Grid">
          <Setter Property="Background" Value="{StaticResource Black40}"/>
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsAggroSwapRecent, FallbackValue=False}" Value="True">
              <Setter Property="Background" Value="#D4A030"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsBossTargetingYou, FallbackValue=False}" Value="True">
              <Setter Property="Background" Value="#AA2222"/>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Grid.Style>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="24"/>
        <ColumnDefinition Width="24"/>
        <ColumnDefinition Width="24"/>
      </Grid.ColumnDefinitions>

      <Image Grid.Column="0" Source="{Binding IconPath}" Width="20" Height="20" Margin="2 0 0 0"/>
      <TextBlock Grid.Column="1" Margin="3 0 0 0" VerticalAlignment="Center"
                 TextTrimming="CharacterEllipsis">
        <TextBlock.Style>
          <Style TargetType="TextBlock">
            <Setter Property="Text" Value="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsBossTargetingSomeoneElse, FallbackValue=False}" Value="True">
                <Setter Property="Text" Value="{Binding AggroTargetText}"/>
              </DataTrigger>
              <DataTrigger Binding="{Binding IsBossTargetingYou, FallbackValue=False}" Value="True">
                <Setter Property="Text" Value="{Binding IsBossTargetingYouText}"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </TextBlock.Style>
      </TextBlock>
      <Button Grid.Column="2"
              Click="ResetButton_Click_Reset"
              ToolTip="Reset">
        <fa:ImageAwesome Icon="Refresh"/>
      </Button>
      <Button Grid.Column="3"
              Click="MinimizeButton_Click_Minimize"
              ToolTip="Minimize">
        <fa:ImageAwesome Icon="WindowMinimize"/>
      </Button>
      <Button Grid.Column="4"
              Click="CloseButton_Click_Close"
              ToolTip="Close">
        <fa:ImageAwesome Icon="Close"/>
      </Button>
    </Grid>

    <Grid Grid.Row="1"
          Background="{StaticResource DarkBlueBrush85}">
      <ContentControl x:Name="BossModuleViewContent"/>
    </Grid>

    <Border Grid.Row="1"
            BorderBrush="{StaticResource LightBlueBrush}" BorderThickness="0 1 0 0"/>

    <Popup x:Name="StatusBarsPopup"
           PlacementTarget="{Binding RelativeSource={RelativeSource AncestorType=Window}, Mode=OneTime}"
           Placement="Custom"
           IsOpen="{Binding HasStatusBars, Mode=OneWay}"
           StaysOpen="True"
           AllowsTransparency="True"
           Focusable="False">
      <ItemsControl ItemsSource="{Binding StatusBars}"
                    Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                    Background="Transparent">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Orientation="Vertical"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Grid Height="18" Margin="10 0 10 4">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Image Grid.Column="0"
                     Source="{Binding IconPath}"
                     Width="18" Height="18"
                     Stretch="UniformToFill"/>
              <Grid Grid.Column="1">
                <ProgressBar Minimum="0"
                             Foreground="{Binding BarColor, Converter={StaticResource ColorToRowBrushConverter}}"
                             Background="{StaticResource DarkBlueBrush81}"
                             behaviors:StatusBarAnimation.StatusBarViewModel="{Binding}">
                  <ProgressBar.Template>
                    <ControlTemplate TargetType="ProgressBar">
                      <Grid>
                        <Border x:Name="PART_Track" Background="{TemplateBinding Background}"/>
                        <Decorator x:Name="PART_Indicator" HorizontalAlignment="Left">
                          <Rectangle Fill="{TemplateBinding Foreground}"/>
                        </Decorator>
                      </Grid>
                    </ControlTemplate>
                  </ProgressBar.Template>
                </ProgressBar>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Column="0" Text="{Binding Label}"
                             Style="{StaticResource StatusBarLabelStyle}"
                             TextTrimming="CharacterEllipsis"
                             Margin="4 0 0 0"/>
                  <TextBlock Grid.Column="1" Text="{Binding RightText}"
                             Style="{StaticResource StatusBarLabelStyle}"
                             Margin="0 0 4 0"/>
                </Grid>
              </Grid>
            </Grid>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Popup>
  </Grid>
</Window>
