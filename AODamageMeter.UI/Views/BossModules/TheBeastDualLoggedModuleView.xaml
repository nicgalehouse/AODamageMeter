<UserControl x:Class="AODamageMeter.UI.Views.BossModules.TheBeastDualLoggedModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid TextBlock.FontSize="14" TextBlock.FontWeight="Bold">
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <Border Grid.Row="0" Grid.Column="0">
      <Border.Style>
        <Style TargetType="Border">
          <Style.Triggers>
            <DataTrigger Binding="{Binding HasWipedNanoPrograms}" Value="True">
              <Setter Property="Background">
                <Setter.Value>
                  <ImageBrush ImageSource="/Icons/NcuWipe.png" Stretch="UniformToFill"/>
                </Setter.Value>
              </Setter>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="2 0">
        <TextBlock Text="{Binding PrimaryCharacterName}" Foreground="White" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
        <TextBlock Text="NCU Wipes" Foreground="White" FontSize="10" HorizontalAlignment="Center">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Style.Triggers>
                <DataTrigger Binding="{Binding HasWipedNanoPrograms}" Value="True">
                  <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
        <ItemsControl ItemsSource="{Binding WipedNanoPrograms}" Margin="0 4 0 0">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}" Foreground="White" FontSize="10" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center"/>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>

    <Border Grid.Row="0" Grid.Column="1">
      <Border.Style>
        <Style TargetType="Border">
          <Style.Triggers>
            <DataTrigger Binding="{Binding HasSecondaryWipedNanoPrograms}" Value="True">
              <Setter Property="Background">
                <Setter.Value>
                  <ImageBrush ImageSource="/Icons/NcuWipe.png" Stretch="UniformToFill"/>
                </Setter.Value>
              </Setter>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="2 0">
        <TextBlock Text="{Binding SecondaryCharacterName}" Foreground="White" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
        <TextBlock Text="NCU Wipes" Foreground="White" FontSize="10" HorizontalAlignment="Center">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Style.Triggers>
                <DataTrigger Binding="{Binding HasSecondaryWipedNanoPrograms}" Value="True">
                  <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
        <ItemsControl ItemsSource="{Binding SecondaryWipedNanoPrograms}" Margin="0 4 0 0">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}" Foreground="White" FontSize="10" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center"/>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Border>

    <Grid Grid.Row="1" Grid.Column="0">
      <Border>
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsCasting}" Value="True">
                <Setter Property="Background">
                  <Setter.Value>
                    <ImageBrush ImageSource="/Icons/Casting.png" Stretch="UniformToFill"/>
                  </Setter.Value>
                </Setter>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <Border.Opacity>
          <Binding Path="CastingOpacity" FallbackValue="0"/>
        </Border.Opacity>
      </Border>
      <Border>
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsRingOfFireActive}" Value="True">
                <Setter Property="Background">
                  <Setter.Value>
                    <ImageBrush ImageSource="/Icons/RingOfFire.png" Stretch="UniformToFill"/>
                  </Setter.Value>
                </Setter>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
      </Border>
      <TextBlock Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock.Style>
          <Style TargetType="TextBlock">
            <Setter Property="Text" Value="Casting"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsRingOfFireActive}" Value="True">
                <Setter Property="Text" Value="Ring of Fire"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </TextBlock.Style>
        <TextBlock.Effect>
          <DropShadowEffect ShadowDepth="0" BlurRadius="5" Color="Black" Opacity="1"/>
        </TextBlock.Effect>
      </TextBlock>
      <TextBlock Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 36 0 0">
        <TextBlock.Style>
          <Style TargetType="TextBlock">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsCasting}" Value="True">
                <Setter Property="Visibility" Value="Visible"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </TextBlock.Style>
        <TextBlock.Effect>
          <DropShadowEffect ShadowDepth="0" BlurRadius="5" Color="Black" Opacity="1"/>
        </TextBlock.Effect>
        <TextBlock.Text>
          <Binding Path="CastingDurationSeconds" StringFormat="{}{0}s"/>
        </TextBlock.Text>
      </TextBlock>
    </Grid>

    <Border Grid.Row="1" Grid.Column="1">
      <Border.Style>
        <Style TargetType="Border">
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsReflectActive}" Value="True">
              <Setter Property="Background">
                <Setter.Value>
                  <ImageBrush ImageSource="/Icons/ReflectShield.png" Stretch="UniformToFill"/>
                </Setter.Value>
              </Setter>
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <Grid>
        <TextBlock Text="Reflects" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center">
          <TextBlock.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="5" Color="Black" Opacity="1"/>
          </TextBlock.Effect>
        </TextBlock>
        <TextBlock Text="{Binding ReflectCountdown}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 36 0 0">
          <TextBlock.Effect>
            <DropShadowEffect ShadowDepth="0" BlurRadius="5" Color="Black" Opacity="1"/>
          </TextBlock.Effect>
        </TextBlock>
      </Grid>
    </Border>

    <Rectangle Grid.Row="0" Grid.ColumnSpan="2" VerticalAlignment="Bottom" Height="1" Fill="Gray"/>
    <Rectangle Grid.Column="0" Grid.RowSpan="2" HorizontalAlignment="Right" Width="1" Fill="Gray"/>
  </Grid>
</UserControl>
