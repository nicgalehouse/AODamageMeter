<Window x:Class="AODamageMeter.UI.Views.AutoConfigureView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:properties="clr-namespace:AODamageMeter.UI.Properties"
        Title="Auto-configure Options"
        Style="{StaticResource WindowStyle}" Background="Transparent"
        BorderBrush="{StaticResource LightBlueBrush50}" BorderThickness="1"
        Height="{Binding Source={x:Static properties:Settings.Default}, Path=AutoConfigureViewHeight, Mode=TwoWay}"
        Width="{Binding Source={x:Static properties:Settings.Default}, Path=AutoConfigureViewWidth, Mode=TwoWay}"
        Top="{Binding Source={x:Static properties:Settings.Default}, Path=AutoConfigureViewTop, Mode=TwoWay}"
        Left="{Binding Source={x:Static properties:Settings.Default}, Path=AutoConfigureViewLeft, Mode=TwoWay}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="24"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0"
          Background="{StaticResource Black40}"
          MouseDown="HeaderRow_MouseDown_Drag">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="24"/>
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Column="0"
                 Margin="5 0 0 0" VerticalAlignment="Center"
                 Text="Auto-configure Options"/>
      <Button Grid.Column="1" IsCancel="True"
              ToolTip="Close">
        <fa:ImageAwesome Icon="Close"/>
      </Button>
    </Grid>

    <Grid Grid.Row="1" Margin="1"
          Background="{StaticResource DarkBlueBrush85}">
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <StackPanel Grid.Row="0" Margin="10">
        <CheckBox x:Name="IncludeSystemChannelCheckBox"
                  IsChecked="{Binding Source={x:Static properties:Settings.Default}, Path=IncludeSystemChannel}"
                  Content="Include System channel"/>
        <TextBlock Margin="17 2 0 0" TextWrapping="Wrap"
                   Text="The System channel is necessary for some Boss module features and for tracking self nano heals, health drains, nano drains, nano interrupts, and blocked hits. But it can blow up the log file size so good chat filters are recommended. See the readme for tips on chat filters."/>
      </StackPanel>

      <StackPanel Grid.Row="1" Margin="10 0 10 10" Orientation="Horizontal"
                  HorizontalAlignment="Right" VerticalAlignment="Bottom">
        <Button Style="{StaticResource TextButtonStyle}"
                Content="Go" Click="GoButton_Click"/>
        <Button Margin="5 0 0 0" Style="{StaticResource TextButtonStyle}"
                Content="Cancel" IsCancel="True"/>
      </StackPanel>
    </Grid>

    <Border Grid.Row="1" Margin="0"
            BorderBrush="{StaticResource Black40}" BorderThickness="1"/>
    <Border Grid.Row="1" Margin="2 0 2 2"
            BorderBrush="{StaticResource LightBlueBrush}" BorderThickness="1"/>
  </Grid>
</Window>
